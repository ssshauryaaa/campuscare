FROM node:20-alpine
WORKDIR /app

# Install native build tools for better-sqlite3
RUN apk add --no-cache python3 make g++

# We DON'T copy source here — it comes from the volume mount
# We only pre-install deps so the volume mount can override node_modules

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NODE_ENV=development

CMD ["npm", "run", "dev"]